# ============================================================================
# UEM — LOCAL / CLI mode environment
# Copy this file to `.env` inside backend-node/ before running the CLI or the
# local backend:   cp .env.local.example .env   (Windows: copy .env.local.example .env)
# ============================================================================

# --- Storage: keep BOTH the CLI and the backend pointed at the SAME folder ---
STORAGE_BACKEND=local
# Absolute path recommended. The CLI writes here; the backend reads from here.
LOCAL_STORAGE_DIR=./uem-data

# --- AWS Bedrock (required for AI analysis) ---------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_KEY_HERE
# If you use temporary creds, also set:
# AWS_SESSION_TOKEN=your-session-token

# --- Models -----------------------------------------------------------------
BEDROCK_DEFAULT_MODEL=anthropic.claude-sonnet-4-5
BEDROCK_ANALYSIS_MAX_TOKENS=16384
BEDROCK_TIMEOUT=180

# --- Server (only needed when running the backend to serve the dashboard) ---
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=dev
CORS_ALLOWED_ORIGINS=*

# --- Limits -----------------------------------------------------------------
MAX_FINDINGS_PER_SCAN=2000
