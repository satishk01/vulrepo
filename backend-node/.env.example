# =============================================================================
# UEM Backend (Node.js) — local Windows run
# Copy this to ".env" in the backend-node/ folder and fill in your values.
# =============================================================================

# --- AWS credentials (your admin access key) ---
# Used by Bedrock (required) and S3/Secrets Manager (only if you opt in).
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_KEY_HERE
AWS_REGION=us-east-1

# --- Bedrock model ---
# Enable in AWS console: Bedrock -> Model access -> request Claude Sonnet 4.5
BEDROCK_DEFAULT_MODEL=anthropic.claude-sonnet-4-5
BEDROCK_MAX_TOKENS=8192
BEDROCK_TIMEOUT=120

# --- Storage backend ---
# "local" = filesystem on this laptop, "s3" = original cloud behavior.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=C:\uem-data
S3_PREFIX=uem
# Only used if STORAGE_BACKEND=s3
# S3_BUCKET=my-uem-bucket

# --- GitHub token (optional — only for private repos) ---
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Workspace (where zips/clones get extracted) ---
WORKSPACE_DIR=C:\uem-workspace
MAX_REPO_SIZE_MB=500
MAX_ZIP_SIZE_MB=200
MAX_FINDINGS_PER_SCAN=2000

# Analysis batching: findings per AI call. At/below this number the backend
# uses the original single-call analysis; above it, it batches + merges so
# large scans (20+ findings) no longer truncate and break the dashboard.
ANALYSIS_BATCH_SIZE=8

# --- Server behavior ---
PORT=8000
HOST=127.0.0.1
RATE_LIMIT_PER_MINUTE=120
CORS_ALLOWED_ORIGINS=*
ENVIRONMENT=dev
LOG_LEVEL=info
