# =============================================================================
# UEM Frontend - local Windows dev
# Copy this to ".env.local" in the frontend/ folder.
# Vite reads VITE_* variables and exposes them to the browser at build/dev time.
# =============================================================================

# Where the browser should send API calls. For local dev with the Vite proxy,
# leave this commented out — the proxy in vite.config.js will route /api/* to
# http://localhost:8000 automatically.
#
# Only set this if you want to bypass the proxy (e.g. when running the backend
# on a different machine / port).
# VITE_API_URL=http://localhost:8000
